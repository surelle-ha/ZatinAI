{
  "name": "tetragram",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "fastify": "5.8.2"
    }
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter api start:dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.55.0"
  }
}