{
  "name": "monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "lerna run dev --scope web",
    "dev:api": "lerna run start:dev --scope api",
    "build": "lerna run build",
    "lint": "lerna run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "lerna": "^9.0.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.55.0"
  }
}
